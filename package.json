{
  "name": "madan-paints",
  "version": "1.0.0",
  "description": "Madan Paints - Premium Paints & Coatings E-commerce",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "build:client": "cd client && npm run build",
    "start": "node server/server.js",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "keywords": ["paints", "ecommerce", "react", "express"],
  "license": "MIT"
}
